{
  "manifest_version": 3,
  "name": "Listenr — Read any page aloud",
  "version": "0.6.0",
  "description": "Reads the readable text of any web page aloud with synced highlighting and keyboard controls.",
  "permissions": ["scripting", "storage", "offscreen", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Listenr"
  },
  "commands": {
    "rate-up": {
      "suggested_key": { "mac": "Option+Up", "default": "Alt+Up" },
      "description": "Increase speed by 0.1x"
    },
    "rate-down": {
      "suggested_key": { "mac": "Option+Down", "default": "Alt+Down" },
      "description": "Decrease speed by 0.1x"
    },
    "toggle-play": {
      "description": "Play / Pause"
    },
    "next-sentence": {
      "suggested_key": { "mac": "Option+Right", "default": "Alt+Right" },
      "description": "Skip to next sentence"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
